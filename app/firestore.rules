rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isStudent() {
      return request.auth != null
        && request.auth.token.email.matches('.*@uniandes\\.edu\\.co');
    }

    function isVerifiedStudent() {
      return isStudent()
        && request.auth.token.email_verified == true;
    }

    match /users/{userId} {
      allow read: if isVerifiedStudent();
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update, delete: if isVerifiedStudent() && request.auth.uid == userId;
    }

    match /listings/{listingId} {
      allow read: if isVerifiedStudent();
      allow create: if isVerifiedStudent()
        && request.resource.data.sellerId == request.auth.uid;
      allow update, delete: if isVerifiedStudent()
        && resource.data.sellerId == request.auth.uid;
    }

    match /meetup_transactions/{transactionId} {
      allow read: if isVerifiedStudent();

      // Seller creates a pending transaction assigned to a buyer.
      allow create: if isVerifiedStudent()
        && request.resource.data.sellerId == request.auth.uid
        && request.resource.data.status == 'pending'
        && request.resource.data.confirmedAt == null;

      // Assigned buyer confirms a pending transaction.
      allow update: if isVerifiedStudent()
        && resource.data.buyerId == request.auth.uid
        && resource.data.status == 'pending'
        && request.resource.data.status == 'confirmed'
        && request.resource.data.transactionId == resource.data.transactionId
        && request.resource.data.listingId == resource.data.listingId
        && request.resource.data.sellerId == resource.data.sellerId
        && request.resource.data.buyerId == resource.data.buyerId;

      allow delete: if false;
    }

    match /conversations/{conversationId} {
      allow read, write: if isVerifiedStudent() && request.auth.uid in resource.data.participants;
      match /messages/{messageId} {
        allow read: if isVerifiedStudent() && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants;
        allow create: if isVerifiedStudent() && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants && request.resource.data.senderId == request.auth.uid;
        allow update: if isVerifiedStudent() && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants && request.resource.data.diff(resource.data).affectedKeys() == ['readAt'].toSet();
      }
    }
  }
}